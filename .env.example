# Copy to .env (or .env.local) and fill in. Vite reads these at BUILD time —
# restart `npm run dev` / re-run `npm run build` after changing them.
# Only VITE_-prefixed vars are exposed to the client bundle; everything here
# is public (addresses, URLs, anon key) — never put private keys in VITE_ vars.

# Which Robinhood Chain network to use (see src/network.js): testnet | mainnet.
# Must match the NETWORK secret set on the Supabase edge functions.
VITE_NETWORK=testnet

# $FIGHT10 ERC-20 contract address on the selected network (0x + 40 hex chars).
VITE_FIGHT10_TOKEN=0x0000000000000000000000000000000000000000

# Escrow wallet PUBLIC address deposits are paid into (0x + 40 hex chars).
VITE_ESCROW_WALLET=0x0000000000000000000000000000000000000000

# Token decimals (standard ERC-20 is 18). Must match the deployed contract.
VITE_FIGHT10_DECIMALS=18

# Optional: dedicated RPC endpoint (e.g. Alchemy/QuickNode key) — defaults to
# the network's public RPC from src/network.js.
# VITE_ROBINHOOD_RPC_URL=

# Optional: "Buy $FIGHT10" link (e.g. a DEX swap URL) — defaults to the
# token's Blockscout page.
# VITE_BUY_FIGHT10_URL=

# Supabase project.
VITE_SUPABASE_URL=https://sajvismyvcgaszjcafcr.supabase.co
VITE_SUPABASE_ANON_KEY=
