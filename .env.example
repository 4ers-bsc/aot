# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=

# $FIGHT10 tokenomics (fill in after Pump.fun deployment)
VITE_FIGHT10_MINT=       # SPL token mint address
VITE_ESCROW_WALLET=      # Public key of the escrow/treasury wallet
VITE_SOLANA_RPC=https://api.mainnet-beta.solana.com

# --- Supabase Edge Function secrets (set via: supabase secrets set KEY=value) ---
# ESCROW_PRIVATE_KEY=    # base58 private key of the escrow wallet (NEVER commit)
# FIGHT10_MINT=          # same mint address as above
# RPC_URL=               # Solana RPC endpoint
