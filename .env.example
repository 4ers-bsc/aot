# -----------------------------------------------------------------------------
# FIGHT10 — client (Vite) environment
# Copy this file to `.env` and fill in the values. Only VITE_* vars are exposed
# to the browser, so never put a private key here. The network itself
# (Robinhood Chain mainnet) is defined in src/network.js — no env var needed.
# -----------------------------------------------------------------------------

# $FIGHT10 ERC-20 contract address (0x…40 hex). Required for live deposits.
VITE_FIGHT10_TOKEN=<FIGHT10_TOKEN_ADDRESS>

# Escrow wallet PUBLIC address (0x…40 hex) — deposits are sent here. Required.
VITE_ESCROW_WALLET=<ESCROW_WALLET_ADDRESS>

# Token decimals (standard ERC-20 is 18). Optional.
VITE_FIGHT10_DECIMALS=18

# Override the network's public RPC (e.g. a dedicated key). Optional.
# VITE_ROBINHOOD_RPC_URL=https://rpc.mainnet.chain.robinhood.com

# "Buy $FIGHT10" link (e.g. a DEX swap URL). Optional — defaults to the token's
# Blockscout explorer page.
# VITE_BUY_FIGHT10_URL=

# Supabase project. Required for auth / realtime / edge functions.
VITE_SUPABASE_URL=https://sajvismyvcgaszjcafcr.supabase.co
VITE_SUPABASE_ANON_KEY=<SUPABASE_ANON_KEY>
