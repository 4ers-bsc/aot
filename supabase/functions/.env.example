# -----------------------------------------------------------------------------
# FIGHT10 — Supabase edge function secrets (f10join / f10treasurer / f10admin)
#
# In production these are set as Supabase secrets:
#   supabase secrets set --env-file supabase/functions/.env
# For local `supabase functions serve`, copy this file to
# `supabase/functions/.env` and fill it in.
#
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY are injected by
# the platform automatically — you do NOT set them here.
# -----------------------------------------------------------------------------

# $FIGHT10 ERC-20 contract address — used by all three functions. Required.
FIGHT10_TOKEN=<FIGHT10_TOKEN_ADDRESS>

# Escrow PUBLIC address (deposit destination) — used by f10join. Required.
ESCROW_WALLET=<ESCROW_WALLET_ADDRESS>

# Escrow signer private key, 0x-prefixed hex — used by f10treasurer & f10admin
# to sign payouts. KEEP SECRET. Required for payouts.
ESCROW_PRIVATE_KEY=<ESCROW_PRIVATE_KEY>

# Optional RPC pool (round-robin + failover); falls back to the network's RPC.
# RPC_URL=https://rpc.mainnet.chain.robinhood.com
# RPC_URL_2=
# RPC_URL_3=

# Dashboard display decimals for f10admin (on-chain paths read decimals() live).
FIGHT10_DECIMALS=18

# Locks CORS to the game origin — used by all three. Required.
APP_ORIGIN=http://localhost:3000

# Ops dashboard allowlist for f10admin (comma-separated). At least one needed
# to access the admin dashboard.
ADMIN_USER_IDS=
ADMIN_WALLETS=
